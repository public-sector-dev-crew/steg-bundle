{
    "name": "lotse/steg-bundle",
    "description": "Symfony Bundle for Steg — auto-configuration, profiler panel, and DI integration",
    "type": "symfony-bundle",
    "license": "EUPL-1.2",
    "keywords": ["llm", "inference", "symfony", "bundle", "steg", "vllm", "ollama", "ai", "php"],
    "authors": [
        {
            "name": "Andreas Teumer",
            "email": "ndrstmr@outlook.de",
            "homepage": "https://github.com/ndrstmr"
        }
    ],
    "require": {
        "php": ">=8.4",
        "lotse/steg": "^1.0.1",
        "symfony/config": "^7.0|^8.0",
        "symfony/dependency-injection": "^7.0|^8.0",
        "symfony/framework-bundle": "^7.0|^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0",
        "symfony/http-client": "^7.0|^8.0"
    },
    "autoload": {
        "psr-4": {
            "Steg\\Bundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Steg\\Bundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
